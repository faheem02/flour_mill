</div>

<script>
function calcPurchase() {
    var qty = parseFloat($('input[name="total_qty"]').val()) || 0;
    var rate = parseFloat($('input[name="rate_per_kg"]').val()) || 0;
    $('input[name="total_amount"]').val((qty * rate).toFixed(2));
}
</script>

