        <form method="POST" id="purchaseForm">
            <div class="row">
                <div class="col-md-3">
                    <div class="form-group">
                        <label>Supplier <span class="text-danger">*</span></label>
                        <select name="supplier_id" class="form-control" required>
                            <option value="">Select Supplier</option>
